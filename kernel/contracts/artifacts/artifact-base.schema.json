{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://designos.dev/schemas/artifact-base.schema.json",
  "title": "Artifact Base Schema",
  "description": "所有设计推理资产的基础 schema，定义通用元数据、追溯性和质量属性",
  "type": "object",
  "properties": {
    "artifact_id": {
      "type": "string",
      "description": "唯一标识符，格式：{artifact_type}-{timestamp}-{uuid}",
      "pattern": "^[a-z-]+-\\d{8}-[a-f0-9]{8}$",
      "example": "design-objectives-20260609-a1b2c3d4"
    },
    "artifact_type": {
      "type": "string",
      "description": "资产类型，必须是预定义的枚举值",
      "enum": [
        "design_strategy",
        "user_persona",
        "requirement_inventory",
        "product_archetype",
        "design_objectives",
        "user_task_map",
        "scenario_map",
        "business_flow",
        "journey_map",
        "information_architecture",
        "page_flow",
        "page_structure",
        "component_strategy",
        "state_matrix",
        "interaction_rules",
        "design_spec",
        "prototype",
        "ux_issue_report",
        "brand_brief",
        "brand_strategy",
        "logo_spec",
        "color_system",
        "typography_system",
        "visual_spec",
        "ip_persona_profile",
        "ip_worldview",
        "image_prompt_pack",
        "professional_gap_report",
        "traceability_map"
      ]
    },
    "skill_id": {
      "type": "string",
      "description": "生成此资产的 skill 标识符",
      "enum": ["uxeval", "prd2proto", "ai-analytics", "ip-design", "brand-creative"],
      "example": "prd2proto"
    },
    "run_id": {
      "type": "string",
      "description": "执行此 skill 的运行 ID，用于关联同一次执行的所有资产",
      "pattern": "^run-[a-z0-9-]{8,}$",
      "example": "run-abc123-456def"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "资产创建时间，ISO 8601 格式",
      "example": "2026-06-09T10:00:00Z"
    },
    "maturity": {
      "type": "string",
      "description": "资产成熟度状态",
      "enum": ["draft", "reviewable", "validated", "deprecated"],
      "default": "draft"
    },
    "confidence": {
      "type": "number",
      "description": "资产整体置信度，0.0-1.0，反映输入质量和推理可靠性",
      "minimum": 0.0,
      "maximum": 1.0,
      "example": 0.85
    },
    "source_inputs": {
      "type": "array",
      "description": "生成此资产的所有输入来源",
      "items": {
        "type": "object",
        "properties": {
          "input_type": {
            "type": "string",
            "enum": ["prd", "screenshot", "user_story", "design_brief", "existing_artifact", "external_doc"],
            "description": "输入类型"
          },
          "input_id": {
            "type": "string",
            "description": "输入的标识符或文件路径"
          },
          "input_status": {
            "type": "string",
            "enum": ["complete", "partial", "missing"],
            "description": "输入完整性状态"
          },
          "quality_score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "输入质量评分"
          }
        },
        "required": ["input_type", "input_id", "input_status"]
      }
    },
    "inferred_fields": {
      "type": "array",
      "description": "被推断的字段列表，格式：JSON Path",
      "items": {
        "type": "string",
        "example": "user_goals[1].pain_points"
      }
    },
    "gaps": {
      "type": "array",
      "description": "识别的输入缺失或信息不足",
      "items": {
        "type": "object",
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^GAP-\\d{3}$"
          },
          "category": {
            "type": "string",
            "enum": ["missing_input", "ambiguous_requirement", "conflicting_information", "insufficient_detail"]
          },
          "description": {
            "type": "string",
            "description": "Gap 的详细描述"
          },
          "impact": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"],
            "description": "对最终产物的影响程度"
          },
          "affected_fields": {
            "type": "array",
            "items": {"type": "string"},
            "description": "受影响的字段 JSON Path"
          },
          "mitigation": {
            "type": "string",
            "description": "当前的缓解措施（如使用默认值、行业惯例等）"
          }
        },
        "required": ["gap_id", "category", "description", "impact"]
      }
    },
    "warnings": {
      "type": "array",
      "description": "风险警告列表",
      "items": {
        "type": "object",
        "properties": {
          "warning_id": {
            "type": "string",
            "pattern": "^WARN-\\d{3}$"
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "category": {
            "type": "string",
            "enum": ["low_confidence", "assumption_risk", "constraint_violation", "consistency_issue", "scope_creep"]
          },
          "message": {
            "type": "string"
          },
          "recommendation": {
            "type": "string",
            "description": "建议的处理方式"
          }
        },
        "required": ["warning_id", "severity", "category", "message"]
      }
    },
    "assumptions": {
      "type": "array",
      "description": "明确列出的假设",
      "items": {
        "type": "object",
        "properties": {
          "assumption_id": {
            "type": "string",
            "pattern": "^ASM-\\d{3}$"
          },
          "description": {
            "type": "string"
          },
          "rationale": {
            "type": "string",
            "description": "为什么做出这个假设"
          },
          "validation_method": {
            "type": "string",
            "description": "如何验证这个假设"
          },
          "risk_if_wrong": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          }
        },
        "required": ["assumption_id", "description", "risk_if_wrong"]
      }
    },
    "traceability": {
      "type": "object",
      "description": "可追溯性信息",
      "properties": {
        "upstream_artifacts": {
          "type": "array",
          "description": "依赖的上游资产",
          "items": {
            "type": "object",
            "properties": {
              "artifact_id": {"type": "string"},
              "artifact_type": {"type": "string"},
              "relationship": {
                "type": "string",
                "enum": ["derived_from", "constrained_by", "informed_by", "validated_by"]
              }
            },
            "required": ["artifact_id", "artifact_type", "relationship"]
          }
        },
        "decision_trace": {
          "type": "array",
          "description": "关键设计决策的追溯",
          "items": {
            "type": "object",
            "properties": {
              "decision_id": {"type": "string"},
              "decision_point": {"type": "string"},
              "rationale": {"type": "string"},
              "alternatives_considered": {
                "type": "array",
                "items": {"type": "string"}
              },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "source": {"type": "string"},
                    "reference": {"type": "string"}
                  }
                }
              }
            },
            "required": ["decision_id", "decision_point", "rationale"]
          }
        },
        "evidence_map": {
          "type": "object",
          "description": "字段到证据的映射",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "evidence_type": {
                  "type": "string",
                  "enum": ["prd_reference", "user_research", "industry_best_practice", "heuristic", "inferred"]
                },
                "source": {"type": "string"},
                "confidence": {"type": "number", "minimum": 0.0, "maximum": 1.0}
              }
            }
          }
        }
      }
    },
    "validation_status": {
      "type": "object",
      "description": "验证状态",
      "properties": {
        "schema_valid": {
          "type": "boolean",
          "description": "是否通过 schema 验证"
        },
        "business_valid": {
          "type": "boolean",
          "description": "是否通过业务规则验证"
        },
        "human_review_required": {
          "type": "boolean",
          "description": "是否需要人工复核"
        },
        "validation_errors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "error_code": {"type": "string"},
              "field_path": {"type": "string"},
              "message": {"type": "string"},
              "severity": {
                "type": "string",
                "enum": ["error", "warning", "info"]
              }
            }
          }
        }
      },
      "required": ["schema_valid", "human_review_required"]
    },
    "metadata": {
      "type": "object",
      "description": "扩展元数据",
      "properties": {
        "model_version": {
          "type": "string",
          "description": "使用的 LLM 模型版本"
        },
        "generation_time_ms": {
          "type": "integer",
          "description": "生成耗时（毫秒）"
        },
        "tokens_used": {
          "type": "integer",
          "description": "消耗的 tokens 数量"
        },
        "retry_count": {
          "type": "integer",
          "description": "重试次数"
        }
      }
    }
  },
  "required": [
    "artifact_id",
    "artifact_type",
    "skill_id",
    "run_id",
    "created_at",
    "maturity",
    "confidence",
    "source_inputs",
    "inferred_fields",
    "gaps",
    "warnings",
    "traceability",
    "validation_status"
  ]
}
