{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://designos.dev/schemas/professional-gap-report.schema.json",
  "title": "Professional Gap Report",
  "description": "专业差距报告，评估当前产物与资深设计师标准的差距",
  "allOf": [
    {
      "$ref": "./artifact-base.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "evaluated_artifact": {
          "type": "object",
          "description": "被评估的资产",
          "properties": {
            "artifact_id": {"type": "string"},
            "artifact_type": {"type": "string"}
          },
          "required": ["artifact_id", "artifact_type"]
        },
        "rubric_dimensions": {
          "type": "array",
          "description": "评估维度（9 维度模型）",
          "items": {
            "type": "object",
            "properties": {
              "dimension_id": {"type": "string"},
              "dimension_name": {
                "type": "string",
                "enum": [
                  "strategic_alignment",
                  "user_understanding",
                  "design_reasoning_depth",
                  "technical_feasibility",
                  "visual_quality",
                  "interaction_sophistication",
                  "accessibility_compliance",
                  "production_readiness",
                  "documentation_completeness"
                ]
              },
              "score": {
                "type": "integer",
                "minimum": 1,
                "maximum": 10,
                "description": "1-10 分，1-3: Junior, 4-6: Mid, 7-9: Senior, 10: Expert"
              },
              "tier": {
                "type": "string",
                "enum": ["junior", "mid", "senior", "expert"]
              },
              "evidence": {
                "type": "array",
                "items": {"type": "string"},
                "description": "评分依据"
              },
              "gaps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "gap_description": {"type": "string"},
                    "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]},
                    "how_to_improve": {"type": "string"}
                  }
                }
              },
              "strengths": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "required": ["dimension_id", "dimension_name", "score", "tier"]
          }
        },
        "overall_assessment": {
          "type": "object",
          "properties": {
            "overall_score": {
              "type": "number",
              "minimum": 1.0,
              "maximum": 10.0,
              "description": "加权平均分"
            },
            "overall_tier": {
              "type": "string",
              "enum": ["junior", "mid", "senior", "expert"]
            },
            "summary": {
              "type": "string",
              "description": "总体评价"
            },
            "distance_to_senior": {
              "type": "object",
              "description": "距离 Senior 标准的差距",
              "properties": {
                "score_gap": {"type": "number"},
                "key_blockers": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "estimated_improvement_time": {"type": "string"}
              }
            }
          },
          "required": ["overall_score", "overall_tier", "summary"]
        },
        "human_review_requirements": {
          "type": "object",
          "description": "人工复核要求",
          "properties": {
            "review_required": {
              "type": "boolean"
            },
            "review_priority": {
              "type": "string",
              "enum": ["critical", "high", "medium", "low"]
            },
            "review_focus_areas": {
              "type": "array",
              "items": {"type": "string"}
            },
            "recommended_reviewers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "role": {"type": "string", "enum": ["senior_designer", "design_lead", "product_manager", "engineer"]},
                  "why": {"type": "string"}
                }
              }
            },
            "review_questions": {
              "type": "array",
              "items": {"type": "string"},
              "description": "需要人工回答的问题"
            }
          },
          "required": ["review_required", "review_priority"]
        },
        "production_readiness": {
          "type": "object",
          "description": "生产就绪度",
          "properties": {
            "ready_for_production": {
              "type": "boolean"
            },
            "blockers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "blocker": {"type": "string"},
                  "severity": {"type": "string", "enum": ["must_fix", "should_fix", "nice_to_fix"]},
                  "owner": {"type": "string"}
                }
              }
            },
            "risk_assessment": {
              "type": "object",
              "properties": {
                "technical_risk": {"type": "string", "enum": ["high", "medium", "low"]},
                "business_risk": {"type": "string", "enum": ["high", "medium", "low"]},
                "user_experience_risk": {"type": "string", "enum": ["high", "medium", "low"]}
              }
            },
            "recommended_next_steps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "step": {"type": "string"},
                  "priority": {"type": "string", "enum": ["P0", "P1", "P2"]},
                  "estimated_effort": {"type": "string"}
                }
              }
            }
          },
          "required": ["ready_for_production", "blockers"]
        },
        "claims_validation": {
          "type": "object",
          "description": "可声称 vs 不可声称",
          "properties": {
            "can_claim": {
              "type": "array",
              "items": {"type": "string"},
              "description": "可以对外宣称的能力"
            },
            "cannot_claim": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "claim": {"type": "string"},
                  "reason": {"type": "string"},
                  "required_to_claim": {"type": "string"}
                }
              },
              "description": "不能宣称的能力及原因"
            },
            "qualified_claims": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "claim": {"type": "string"},
                  "qualification": {"type": "string"}
                }
              },
              "description": "需要加限定词的声称"
            }
          }
        },
        "improvement_roadmap": {
          "type": "array",
          "description": "改进路线图",
          "items": {
            "type": "object",
            "properties": {
              "phase": {"type": "string"},
              "focus_dimensions": {
                "type": "array",
                "items": {"type": "string"}
              },
              "actions": {
                "type": "array",
                "items": {"type": "string"}
              },
              "expected_score_improvement": {"type": "number"},
              "estimated_duration": {"type": "string"}
            }
          }
        },
        "benchmarking": {
          "type": "object",
          "description": "对标行业标准",
          "properties": {
            "industry_average": {"type": "number"},
            "top_tier_benchmark": {"type": "number"},
            "current_position": {"type": "string", "enum": ["below_average", "average", "above_average", "top_tier"]},
            "competitive_analysis": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "competitor": {"type": "string"},
                  "score": {"type": "number"},
                  "key_differentiators": {
                    "type": "array",
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        }
      },
      "required": [
        "evaluated_artifact",
        "rubric_dimensions",
        "overall_assessment",
        "human_review_requirements",
        "production_readiness",
        "claims_validation"
      ]
    }
  ]
}
