# DesignOS environment variables.
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# ---- LLM provider keys ----
# Anthropic API key (Claude family).
ANTHROPIC_API_KEY=

# Deepseek / OpenAI-compatible API key (used as fallback).
DEEPSEEK_API_KEY=

# Optional: override Anthropic / OpenAI base URLs (e.g. for internal proxies).
ANTHROPIC_BASE_URL=

# ---- Model selection ----
# Primary model identifier (defaults to claude-opus-4-7).
DESIGNOS_PRIMARY_MODEL=claude-opus-4-7

# Fallback model identifier (defaults to deepseek-v3).
DESIGNOS_FALLBACK_MODEL=deepseek-v3
