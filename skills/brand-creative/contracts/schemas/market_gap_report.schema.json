{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brand-creative/market_gap_report",
  "title": "market_gap_report",
  "description": "市场空白报告(internal)。competitive-analysis 产出,供 brand-strategy 消费。",
  "type": "object",
  "required": [
    "gaps"
  ],
  "properties": {
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "dimension": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "dimension",
          "description"
        ]
      }
    }
  },
  "additionalProperties": true
}
