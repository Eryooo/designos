  "description": "创意概念集合(internal)。campaign-creative 产出。",
  "type": "object",
  "required": [
    "concepts"
  ],
  "properties": {
    "concepts": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
