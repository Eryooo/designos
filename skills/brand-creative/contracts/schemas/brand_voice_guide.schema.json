{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "brand-creative/brand_voice_guide",
  "title": "brand_voice_guide",
  "description": "品牌声音指南(internal,也作 content_plan 公开)。brand-voice 产出。",
  "type": "object",
  "required": [
    "tone_dimensions",
    "scene_scripts",
    "red_lines"
  ],
  "properties": {
    "tone_dimensions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object"
      }
    },
    "scene_scripts": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object"
      }
    },
    "catchphrases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "red_lines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "content_principles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
